---
interface Props {
  index?: string;
  label: string;
  title?: string;
  id?: string;
  class?: string;
}
const { index, label, title, id, class: klass } = Astro.props;
---

<section class:list={['section', klass]} id={id}>
  <div class="section-head">
    <p class="label">
      {index && <span class="idx">{index}</span>}
      {index && ' · '}{label}
    </p>
    {title && <h2 class="section-title">{title}</h2>}
  </div>
  <div class="section-body">
    <slot />
  </div>
</section>

<style>
  .section {
    padding-block: var(--sp-7);
    border-top: var(--hair) solid var(--hairline);
  }
  .section-head {
    margin-bottom: var(--sp-5);
  }
  .section-title {
    margin-top: var(--sp-3);
    max-width: 24ch;
  }
</style>
