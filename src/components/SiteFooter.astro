---
import { SITE, SHOW_EMAIL } from '../config';
import { url } from '../lib/url';
import Mark from './Mark.astro';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="footer-word plain" href={url('/')}>
        <Mark size={16} />
        <span>{SITE.wordmark}</span>
      </a>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <span class="label"><span class="idx">↳</span> Elsewhere</span>
      <a class="plain" href={SITE.githubUrl} rel="me noopener" target="_blank">GitHub ↗</a>
      <a class="plain" href={url('/about')}>About</a>
      <a class="plain" href={url('/how-i-work')}>How I Work</a>
      <a class="plain" href={url('/glossary')}>Glossary</a>
      {
        SHOW_EMAIL && (
          <a class="plain" href={`mailto:${SITE.email}`}>
            Email
          </a>
        )
      }
    </nav>

    <div class="footer-colophon">
      <p class="footer-fine">© {year} {SITE.author}</p>
      <p class="footer-fine footer-set">Built with Astro. Type set in Archivo and Inter.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--sp-9);
    border-top: var(--hair) solid var(--hairline);
    background: var(--bg-tint);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: var(--sp-6);
    padding-block: var(--sp-7);
  }
  .footer-word {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 760;
    font-stretch: var(--display-stretch);
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.015em;
    color: var(--ink);
  }
  .footer-tag {
    margin-top: var(--sp-3);
    max-width: 34ch;
    color: var(--ink-soft);
    font-size: var(--step-0);
  }
  .footer-fine {
    color: var(--muted);
    font-size: var(--step--1);
    line-height: 1.6;
  }
  .footer-brand .footer-fine {
    margin-top: var(--sp-3);
    max-width: 42ch;
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: flex-start;
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }
  .footer-links .label {
    margin-bottom: 0.2rem;
  }
  .footer-links a {
    color: var(--muted);
  }
  .footer-links a:hover {
    color: var(--brand);
  }
  .footer-colophon {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    text-align: right;
  }
  .footer-set {
    margin-top: auto;
    color: var(--faint);
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-colophon {
      text-align: left;
    }
  }
  @media (max-width: 520px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
