---
/** The site mark: an ember filament (brand) with an amber weight (Lichtspiel)
 *  and two teal chimes (Windchime), the two projects hanging from one line. */
interface Props {
  size?: number;
  class?: string;
}
const { size = 18, class: klass } = Astro.props;
const h = Math.round((size * 18) / 16);
---

<svg
  class={klass}
  width={size}
  height={h}
  viewBox="0 0 16 18"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <line x1="8" y1="1.6" x2="8" y2="11" stroke="var(--brand)" stroke-width="2" stroke-linecap="round"
  ></line>
  <circle cx="8" cy="14.5" r="2.1" fill="var(--ls)"></circle>
  <circle cx="2.7" cy="5" r="1.3" fill="var(--wc)"></circle>
  <circle cx="13.3" cy="5" r="1.3" fill="var(--wc)"></circle>
</svg>
