---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import SpecSheet from '../../components/SpecSheet.astro';
import Badge from '../../components/Badge.astro';
import Timeline from '../../components/Timeline.astro';
import { projectBundle, toTimeline, type Product } from '../../lib/content';
import { STATUS_TONE, label as lbl } from '../../lib/taxonomy';
import { PROJECT_META } from '../../config';
import { url } from '../../lib/url';
import { fmtDate } from '../../lib/format';
import FlowDiagram from '../../components/FlowDiagram.astro';
import Kanban from '../../components/Kanban.astro';
import MonomeTwin from '../../components/MonomeTwin.astro';
import LatentMap from '../../components/LatentMap.astro';

type Stage = { label: string; note?: string };
const DIAGRAMS: Record<Product, { stages: Stage[]; outputs: Stage[]; caption: string }> = {
  windchime: {
    stages: [
      { label: 'Voice', note: 'microphone' },
      { label: 'ASR', note: 'on-device' },
      { label: 'Retrieval', note: 'ALM + FAISS' },
      { label: 'Guarded planner', note: 'fills a schema' },
    ],
    outputs: [
      { label: 'Live-coded audio', note: 'Strudel' },
      { label: 'Generative visuals', note: 'p5 / Three.js' },
      { label: 'monome LEDs' },
    ],
    caption: 'One direction of flow, from a spoken phrase to sound, light, and hardware.',
  },
  lichtspiel: {
    stages: [
      { label: 'Ableton Live', note: 'the set' },
      { label: 'Max for Live', note: 'thin shell' },
      { label: 'Node bridge', note: 'validate and route' },
    ],
    outputs: [
      { label: 'p5 runtime', note: 'renders on stage' },
      { label: 'ML service', note: 'authoring time only' },
      { label: 'monome grid + arc' },
    ],
    caption:
      'The live set drives visuals through a bridge. The model stays off the performance path.',
  },
};
/** Caption for the stylized monome twin, per project. */
const HARDWARE: Record<Product, string> = {
  windchime:
    'A monome Grid and Arc sit with the display, reprogrammed per scene over serialosc and ' +
    'controlling visual parameters only (no tactile path reaches the audio). The interface ' +
    'mirrors every LED in an on-screen digital twin with a plain-language legend, so the ' +
    'mapping is legible before a visitor touches it.',
  lichtspiel:
    'The monome is the instrument: a capability-adaptive mapping folds each sketch onto ' +
    'whatever hardware is plugged in, from a Grid 64 with an Arc 2 up to a Grid 128 with an ' +
    'Arc 4. The same on-screen twin keeps the piece fully playable with no hardware at all, ' +
    'which is also how it survives an unreliable stage.',
};

const CREDITS: Record<Product, { context: string; tools: string[] }> = {
  windchime: {
    context: 'Shown at Gray Area, San Francisco',
    tools: ['monome', 'Strudel', 'p5.js', 'Three.js'],
  },
  lichtspiel: {
    context: 'Built at a Music Hackspace hackathon, Berklee',
    tools: ['Ableton Live', 'Max for Live', 'monome'],
  },
};

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const d = project.data;
const slug = project.id as Product;
const meta = PROJECT_META[slug];
const diagram = DIAGRAMS[slug];
const credit = CREDITS[slug];
const { Content } = await render(project);
const bundle = await projectBundle(slug);
const timeline = toTimeline(bundle);

const otherSlug: Product = slug === 'windchime' ? 'lichtspiel' : 'windchime';
const otherMeta = PROJECT_META[otherSlug];

const specRows = [
  { term: 'Role', value: d.role },
  { term: 'Timeframe', value: d.timeframe },
  { term: 'Audience', value: d.audience },
  {
    term: 'Collaborators',
    value: d.collaborators.length ? d.collaborators.join(', ') : 'Solo',
  },
  { term: 'Stack', values: d.tech },
];

let n = 0;
const idx = () => String(++n).padStart(2, '0');
---

<BaseLayout title={d.title} description={d.summary} accent={slug}>
  <article data-accent={slug}>
    <header class="phero">
      <div class="container">
        <a class="phero-back plain" href={url('/projects')}>← All projects</a>
        <div class="phero-top">
          <span class="phero-kind">{meta?.kind}</span>
          <Badge tone={STATUS_TONE[d.status] ?? 'neutral'}>{lbl(d.status)}</Badge>
        </div>
        <div class="phero-idrow">
          {meta?.logo && <img class="phero-logo" src={url(meta.logo)} alt="" aria-hidden="true" />}
          <h1 class="phero-title">{d.title}</h1>
        </div>
        <p class="phero-summary">{d.summary}</p>
        <div class="phero-thesis">
          <span class="label"><span class="idx">✳</span> Thesis</span>
          <p>{d.thesis}</p>
        </div>
        <div class="phero-credits">
          <span class="credit-context">{credit.context}</span>
          <span class="credit-tools">
            {credit.tools.map((t) => <span class="credit-chip">{t}</span>)}
          </span>
        </div>
        {
          meta?.art && (
            <figure class="phero-media">
              <img src={url(meta.art)} alt={meta.artAlt} loading="lazy" />
            </figure>
          )
        }
      </div>
    </header>

    <div class="container pbody">
      <Section index={idx()} label="At a glance" id="glance">
        <div class="glance">
          <SpecSheet rows={specRows} />
          <div class="glance-side">
            <div class="callout">
              <span class="label">The problem</span>
              <p>{d.problem}</p>
            </div>
          </div>
        </div>
        {
          d.constraints.length > 0 && (
            <div class="constraints">
              <span class="label">Constraints that shaped it</span>
              <ul class="constraint-list">
                {d.constraints.map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            </div>
          )
        }
      </Section>

      {
        diagram && (
          <Section index={idx()} label="Architecture" title="How it fits together">
            <FlowDiagram
              stages={diagram.stages}
              outputs={diagram.outputs}
              caption={diagram.caption}
            />
          </Section>
        )
      }

      <Section index={idx()} label="The hardware" title="Tactile control, mirrored on screen">
        <MonomeTwin caption={HARDWARE[slug]} />
      </Section>

      {
        slug === 'windchime' && (
          <Section index={idx()} label="Under the hood" title="Retrieval in embedding space">
            <LatentMap />
          </Section>
        )
      }

      {
        bundle.milestones.length > 0 && (
          <Section index={idx()} label="Roadmap" title="Now, next, later" id="roadmap">
            <Kanban milestones={bundle.milestones} />
          </Section>
        )
      }

      <Section index={idx()} label="The story">
        <div class="prose"><Content /></div>
      </Section>

      {
        timeline.length > 0 && (
          <Section index={idx()} label="Timeline" title="What happened, in order">
            <Timeline events={timeline} />
          </Section>
        )
      }

      {
        bundle.decisions.length > 0 && (
          <Section index={idx()} label="Decisions" title="Decision records" id="decisions">
            <div class="records">
              {bundle.decisions.map((rec) => (
                <details class="rec" id={`rec-${rec.id}`}>
                  <summary>
                    <Badge tone={STATUS_TONE[rec.data.status]}>{lbl(rec.data.status)}</Badge>
                    <span class="rec-title">{rec.data.title}</span>
                    <time class="rec-date">{fmtDate(rec.data.date)}</time>
                  </summary>
                  <div class="rec-body">
                    <p>
                      <strong>Context.</strong> {rec.data.context}
                    </p>
                    <p>
                      <strong>Decision.</strong> {rec.data.decision}
                    </p>
                    <p>
                      <strong>Why.</strong> {rec.data.rationale}
                    </p>
                    <p>
                      <strong>Consequences.</strong> {rec.data.consequences}
                    </p>
                  </div>
                </details>
              ))}
            </div>
          </Section>
        )
      }

      {
        bundle.releases.length > 0 && (
          <Section
            index={idx()}
            label="Releases"
            title="What shipped, and why it mattered"
            id="releases"
          >
            <div class="records">
              {bundle.releases.map((rel) => (
                <details class="rec" id={`rel-${rel.id}`}>
                  <summary>
                    <Badge tone={STATUS_TONE[rel.data.status]}>{lbl(rel.data.status)}</Badge>
                    <span class="rec-title">{rel.data.title}</span>
                    <time class="rec-date">{fmtDate(rel.data.date)}</time>
                  </summary>
                  <div class="rec-body">
                    <p class="rec-tag">{rel.data.version_or_label}</p>
                    <p>{rel.data.summary}</p>
                    <p>
                      <strong>Customer value.</strong> {rel.data.customer_value}
                    </p>
                    {rel.data.included_work.length > 0 && (
                      <ul>
                        {rel.data.included_work.map((w) => (
                          <li>{w}</li>
                        ))}
                      </ul>
                    )}
                  </div>
                </details>
              ))}
            </div>
          </Section>
        )
      }

      {
        bundle.incidents.length > 0 && (
          <Section
            index={idx()}
            label="Incidents"
            title="Bugs, postmortems, follow-through"
            id="incidents"
          >
            <div class="records">
              {bundle.incidents.map((inc) => (
                <details class="rec" id={`inc-${inc.id}`}>
                  <summary>
                    <Badge tone={STATUS_TONE[inc.data.status]}>{lbl(inc.data.status)}</Badge>
                    <span class="rec-title">{inc.data.title}</span>
                    <time class="rec-date">{fmtDate(inc.data.date)}</time>
                  </summary>
                  <div class="rec-body">
                    <p>
                      <strong>Impact.</strong> {inc.data.impact}
                    </p>
                    <p>
                      <strong>Root cause.</strong> {inc.data.root_cause}
                    </p>
                    <p>
                      <strong>Fix.</strong> {inc.data.fix}
                    </p>
                    {inc.data.blameless_note && (
                      <p class="rec-blameless">
                        <strong>Blameless note.</strong> {inc.data.blameless_note}
                      </p>
                    )}
                  </div>
                </details>
              ))}
            </div>
          </Section>
        )
      }

      {
        bundle.research.length > 0 && (
          <Section index={idx()} label="Research" title="How the thinking is tested">
            <div class="records">
              {bundle.research.map((r) => (
                <details class="rec" id={`res-${r.id}`}>
                  <summary>
                    <Badge tone="info">{lbl(r.data.source_type)}</Badge>
                    <span class="rec-title">{r.data.title}</span>
                    <time class="rec-date">{fmtDate(r.data.date)}</time>
                  </summary>
                  <div class="rec-body">
                    <p>{r.data.summary}</p>
                    {r.data.insights.length > 0 && (
                      <>
                        <p class="rec-tag">What it showed</p>
                        <ul>
                          {r.data.insights.map((i) => (
                            <li>{i}</li>
                          ))}
                        </ul>
                      </>
                    )}
                    {r.data.redaction_status !== 'clean' && (
                      <p class="rec-blameless">
                        <strong>Note.</strong> Published as process only. Results and write-ups
                        remain private while under review.
                      </p>
                    )}
                  </div>
                </details>
              ))}
            </div>
          </Section>
        )
      }

      {
        d.outcomes.length > 0 && (
          <Section index={idx()} label="Outcomes" title="What changed">
            <ul class="outcomes">
              {d.outcomes.map((o) => (
                <li>
                  <span class="outcome-mark" aria-hidden="true" />
                  {o}
                </li>
              ))}
            </ul>
          </Section>
        )
      }
    </div>

    <nav class="pnext" aria-label="Other project">
      <div class="container">
        <a class="pnext-link" href={url(`/projects/${otherSlug}`)} data-accent={otherSlug}>
          <span class="label">Next project →</span>
          <span class="pnext-name">{otherMeta?.label}</span>
          <span class="pnext-kind">{otherMeta?.kind}</span>
        </a>
      </div>
    </nav>
  </article>
</BaseLayout>

<style>
  .phero {
    padding-block: var(--sp-8) var(--sp-6);
    border-bottom: var(--hair) solid var(--hairline);
    background:
      radial-gradient(
        60% 120% at 88% -10%,
        color-mix(in oklab, var(--accent) 9%, transparent),
        transparent 70%
      ),
      var(--bg);
  }
  .phero-back {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
  }
  .phero-back:hover {
    color: var(--accent);
  }
  .phero-top {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
  }
  .phero-kind {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }
  .phero-idrow {
    margin-top: var(--sp-3);
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .phero-logo {
    width: clamp(3rem, 6vw, 4.4rem);
    height: clamp(3rem, 6vw, 4.4rem);
    object-fit: contain;
    flex-shrink: 0;
  }
  .phero-title {
    font-size: var(--step-6);
  }
  .phero-media {
    margin: var(--sp-6) 0 0;
    border: var(--hair) solid var(--hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 56rem;
    background: var(--surface-2);
  }
  .phero-media img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 24rem;
    object-fit: cover;
    object-position: top center;
  }
  .phero-summary {
    margin-top: var(--sp-4);
    max-width: 54ch;
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .phero-thesis {
    margin-top: var(--sp-5);
    padding-left: var(--sp-4);
    border-left: 2px solid var(--accent);
    max-width: 60ch;
  }
  .phero-thesis p {
    margin-top: 0.4rem;
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 500;
    color: var(--ink);
    text-wrap: balance;
  }

  .phero-credits {
    margin-top: var(--sp-6);
    display: flex;
    align-items: center;
    gap: var(--sp-3) var(--sp-4);
    flex-wrap: wrap;
  }
  .credit-context {
    font-weight: 600;
    font-size: var(--step--1);
    color: var(--accent);
  }
  .credit-context::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--accent);
    margin-right: 0.5rem;
    vertical-align: middle;
  }
  .credit-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .credit-chip {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    padding: 0.2rem 0.6rem;
    border: var(--hair) solid var(--hairline-strong);
    border-radius: 100px;
  }

  .pbody {
    padding-bottom: var(--sp-6);
  }

  .glance {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  .glance-side {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .callout {
    padding: var(--sp-4);
    border: var(--hair) solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .callout .label {
    color: var(--accent);
  }
  .callout p {
    margin-top: 0.5rem;
    color: var(--ink-soft);
    font-size: var(--step--1);
    line-height: 1.6;
  }
  .callout-muted {
    background: var(--surface-2);
  }
  .callout-muted .label {
    color: var(--muted);
  }
  .constraints {
    margin-top: var(--sp-6);
  }
  .constraint-list {
    margin-top: var(--sp-3);
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: var(--sp-2) var(--sp-5);
  }
  .constraint-list li {
    position: relative;
    padding-left: 1.3rem;
    color: var(--ink-soft);
    font-size: var(--step--1);
    line-height: 1.55;
    padding-block: 0.35rem;
    border-top: var(--hair) solid var(--hairline);
  }
  .constraint-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85rem;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--accent);
  }

  .road {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .road-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .road-h {
    padding-bottom: var(--sp-2);
    border-bottom: 2px solid var(--accent);
  }
  .road-card {
    padding: var(--sp-4);
    border: var(--hair) solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .road-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-2);
  }
  .road-theme {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--faint);
  }
  .road-title {
    margin-top: 0.5rem;
    font-weight: 600;
    color: var(--ink);
  }
  .road-summary {
    margin-top: 0.3rem;
    font-size: var(--step--1);
    color: var(--muted);
    line-height: 1.55;
  }

  .records {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .rec {
    border: var(--hair) solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--surface);
    overflow: hidden;
    transition:
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .rec:hover {
    border-color: color-mix(in oklab, var(--accent) 55%, var(--hairline));
    background: color-mix(in oklab, var(--ink) 8%, var(--surface));
  }
  .rec summary::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--accent);
    margin-left: auto;
    transition: transform 0.2s ease;
  }
  .rec[open] summary::after {
    transform: rotate(45deg);
  }
  .rec summary {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4);
    cursor: pointer;
    list-style: none;
  }
  .rec summary::-webkit-details-marker {
    display: none;
  }
  .rec-title {
    flex: 1;
    font-weight: 560;
    color: var(--ink);
    font-size: var(--step-0);
  }
  .rec-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
  }
  .rec[open] summary {
    border-bottom: var(--hair) solid var(--hairline);
  }
  .rec-body {
    padding: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    color: var(--ink-soft);
    font-size: var(--step--1);
    line-height: 1.6;
  }
  .rec-body ul {
    padding-left: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .rec-body li::marker {
    color: var(--accent);
  }
  .rec-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
  }
  .rec-blameless {
    padding: var(--sp-3);
    background: var(--surface-2);
    border-radius: var(--radius);
    color: var(--muted);
  }

  .outcomes {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(20rem, 100%), 1fr));
    gap: var(--sp-4);
  }
  .outcomes li {
    position: relative;
    padding-left: 1.5rem;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .outcome-mark {
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 9px;
    height: 9px;
    border-radius: 100px;
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 18%, transparent);
  }

  .pnext {
    margin-top: var(--sp-7);
    border-top: var(--hair) solid var(--hairline);
    padding-block: var(--sp-7);
  }
  .pnext-link {
    display: inline-flex;
    flex-direction: column;
    gap: 0.3rem;
    text-decoration: none;
    padding: var(--sp-4) var(--sp-5);
    margin: calc(var(--sp-4) * -1) calc(var(--sp-5) * -1);
    border-radius: var(--radius-lg);
    transition: background 0.15s ease;
  }
  .pnext-link:hover {
    background: color-mix(in oklab, var(--accent) 6%, transparent);
  }
  .pnext-link:hover .pnext-name {
    color: var(--accent);
  }
  .pnext-link .label {
    color: var(--accent);
  }
  .pnext-name {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 750;
    font-stretch: var(--display-stretch);
    text-transform: uppercase;
    color: var(--ink);
  }
  .pnext-kind {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .glance {
      grid-template-columns: 1fr;
    }
    .road {
      grid-template-columns: 1fr;
    }
  }
</style>
