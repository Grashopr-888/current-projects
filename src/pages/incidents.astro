---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecordCard from '../components/RecordCard.astro';
import Badge from '../components/Badge.astro';
import { allIncidents } from '../lib/content';
import { SEVERITY_TONE, STATUS_TONE, label as lbl } from '../lib/taxonomy';

const incidents = await allIncidents();
const resolved = incidents.filter((i) => i.data.status === 'resolved').length;
---

<BaseLayout
  title="Incidents & Iteration"
  description="Bugs, regressions, and blameless postmortems across both products, detection to resolution."
>
  <section class="container wrap">
    <p class="label"><span class="idx">§</span> Incidents &amp; Iteration</p>
    <h1>Bugs, and what they taught.</h1>
    <p class="lead measure">
      The reliability story across both products, as blameless postmortems: impact, root cause, fix,
      and the follow-through. The postmortems say more about how the work is built than the feature
      lists do.
    </p>

    <div class="toolbar">
      <div class="filterbar" role="group" aria-label="Filter by product">
        <button class="filter-btn" data-filter="all" aria-pressed="true">All</button>
        <button class="filter-btn" data-filter="windchime" aria-pressed="false">Windchime</button>
        <button class="filter-btn" data-filter="lichtspiel" aria-pressed="false">Lichtspiel</button>
      </div>
      <span class="count">{resolved} resolved · {incidents.length} total</span>
    </div>

    <div class="list" id="incident-list" data-active="all">
      {
        incidents.map((i) => (
          <RecordCard
            tone={SEVERITY_TONE[i.data.severity] ?? 'warn'}
            badge={lbl(i.data.severity)}
            title={i.data.title}
            date={i.data.date}
            product={i.data.product}
            anchor={`inc-${i.id}`}
          >
            <p class="rec-statusline">
              <Badge tone={STATUS_TONE[i.data.status] ?? 'neutral'} dot={false}>
                {lbl(i.data.status)}
              </Badge>
              <span>{i.data.summary}</span>
            </p>
            <p>
              <strong>Impact.</strong> {i.data.impact}
            </p>
            <p>
              <strong>Detection.</strong> {i.data.detection}
            </p>
            <p>
              <strong>Root cause.</strong> {i.data.root_cause}
            </p>
            <p>
              <strong>Fix.</strong> {i.data.fix}
            </p>
            {i.data.followup_actions.length > 0 && (
              <>
                <p class="rec-sub">Follow-up</p>
                <ul>
                  {i.data.followup_actions.map((a) => (
                    <li>
                      {a.action} <em>({a.status})</em>
                    </li>
                  ))}
                </ul>
              </>
            )}
            {i.data.blameless_note && (
              <p class="rec-blameless">
                <strong>Blameless note.</strong> {i.data.blameless_note}
              </p>
            )}
          </RecordCard>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    padding-block: var(--sp-8) var(--sp-9);
  }
  h1 {
    margin-top: var(--sp-4);
  }
  .lead {
    margin-top: var(--sp-4);
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .toolbar {
    margin-top: var(--sp-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .filterbar {
    display: flex;
    gap: 0.3rem;
  }
  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.4rem 0.8rem;
    border-radius: 100px;
    border: var(--hair) solid var(--hairline-strong);
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-btn[aria-pressed='true'] {
    color: var(--bg);
    background: var(--ink);
    border-color: var(--ink);
  }
  .count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--faint);
  }
  .list {
    margin-top: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .list[data-active='windchime'] :global(.rec[data-product='lichtspiel']),
  .list[data-active='lichtspiel'] :global(.rec[data-product='windchime']) {
    display: none;
  }
  .rec-statusline {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .rec-sub {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--faint);
  }
  .rec-blameless {
    padding: var(--sp-3);
    background: var(--surface-2);
    border-radius: var(--radius);
    color: var(--muted);
  }
</style>

<script>
  const bar = document.querySelector('.filterbar');
  const list = document.getElementById('incident-list');
  bar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-filter]');
    if (!btn || !list) return;
    list.dataset.active = btn.dataset.filter;
    bar
      .querySelectorAll<HTMLElement>('[data-filter]')
      .forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
  });
</script>
