---
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/Badge.astro';
import { allMilestones } from '../lib/content';
import { STATUS_TONE, HORIZON_LABEL, label as lbl } from '../lib/taxonomy';
import { fmtDate } from '../lib/format';
import { PROJECT_META } from '../config';

const milestones = await allMilestones();
const horizons = ['now', 'next', 'later'] as const;
const forward = (h: string) => milestones.filter((m) => m.data.horizon === h);
const shipped = milestones
  .filter((m) => m.data.horizon === 'shipped')
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
---

<BaseLayout
  title="Roadmap"
  description="Where Windchime and Lichtspiel are headed: a combined Now / Next / Later view, plus what already shipped."
>
  <section class="container wrap">
    <p class="label"><span class="idx">§</span> Roadmap</p>
    <h1>Now · Next · Later.</h1>
    <p class="lead measure">
      Both products on one horizon. Forward-looking work is grouped by how soon it's likely to land;
      delivered work is separated out below so the plan never masquerades as done.
    </p>

    <div class="legend">
      <span class="lg" data-accent="windchime"><span class="lg-dot"></span>Windchime</span>
      <span class="lg" data-accent="lichtspiel"><span class="lg-dot"></span>Lichtspiel</span>
    </div>

    <div class="horizons">
      {
        horizons.map((h) => (
          <div class="hcol">
            <span class="label hcol-h">{HORIZON_LABEL[h]}</span>
            <div class="hcards">
              {forward(h).map((m) => (
                <article class="mcard" data-accent={m.data.product}>
                  <div class="mcard-top">
                    <span class="mcard-prod">
                      {PROJECT_META[m.data.product as 'windchime' | 'lichtspiel']?.label ??
                        m.data.product}
                    </span>
                    <Badge tone={STATUS_TONE[m.data.status] ?? 'neutral'} dot={false}>
                      {lbl(m.data.status)}
                    </Badge>
                  </div>
                  <p class="mcard-title">{m.data.title}</p>
                  <p class="mcard-summary">{m.data.summary}</p>
                  {m.data.theme && <span class="mcard-theme">{m.data.theme}</span>}
                </article>
              ))}
              {forward(h).length === 0 && <p class="hempty">None yet.</p>}
            </div>
          </div>
        ))
      }
    </div>

    <div class="shipped">
      <p class="label"><span class="idx">✓</span> Shipped</p>
      <div class="sgrid">
        {
          shipped.map((m) => (
            <article class="scard" data-accent={m.data.product}>
              <div class="scard-top">
                <span class="mcard-prod">
                  {PROJECT_META[m.data.product as 'windchime' | 'lichtspiel']?.label ??
                    m.data.product}
                </span>
                {m.data.date && <time class="scard-date">{fmtDate(m.data.date)}</time>}
              </div>
              <p class="mcard-title">{m.data.title}</p>
              <p class="mcard-summary">{m.data.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    padding-block: var(--sp-8) var(--sp-9);
  }
  h1 {
    margin-top: var(--sp-4);
  }
  .lead {
    margin-top: var(--sp-4);
    font-size: var(--step-1);
    color: var(--ink-soft);
  }
  .legend {
    margin-top: var(--sp-5);
    display: flex;
    gap: var(--sp-4);
  }
  .lg {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }
  .lg-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--accent);
  }

  .horizons {
    margin-top: var(--sp-6);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .hcol-h {
    display: block;
    padding-bottom: var(--sp-2);
    border-bottom: 2px solid var(--brand);
  }
  .hcards {
    margin-top: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .hempty {
    color: var(--faint);
    font-family: var(--font-mono);
  }

  .mcard,
  .scard {
    position: relative;
    padding: var(--sp-4);
    padding-left: calc(var(--sp-4) + 3px);
    border: var(--hair) solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .mcard::before,
  .scard::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--accent);
    opacity: 0.8;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
  }
  .mcard-top,
  .scard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
  }
  .mcard-prod {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }
  .mcard-title {
    margin-top: 0.5rem;
    font-weight: 600;
    color: var(--ink);
  }
  .mcard-summary {
    margin-top: 0.3rem;
    font-size: var(--step--1);
    color: var(--muted);
    line-height: 1.55;
  }
  .mcard-theme {
    display: inline-block;
    margin-top: var(--sp-3);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--faint);
  }
  .scard-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
  }

  .shipped {
    margin-top: var(--sp-8);
    padding-top: var(--sp-6);
    border-top: var(--hair) solid var(--hairline);
  }
  .sgrid {
    margin-top: var(--sp-4);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(22rem, 100%), 1fr));
    gap: var(--sp-3);
  }

  @media (max-width: 820px) {
    .horizons {
      grid-template-columns: 1fr;
    }
  }
</style>
